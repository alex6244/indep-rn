# Base API URL (демо: https://indep.su/api/v1.0 — см. docs/DEMO.md, npm run start:demo).
EXPO_PUBLIC_API_URL=https://indep.su/api/v1.0

# Allow local HTTP fallback URL in development only.
# Allowed: true | false
EXPO_PUBLIC_ALLOW_HTTP_DEV=false

# Request timeout for API calls in milliseconds.
# Example: 10000
EXPO_PUBLIC_API_TIMEOUT_MS=10000

# Allow token fallback to AsyncStorage when SecureStore is unavailable.
# Allowed: true | false
EXPO_PUBLIC_ALLOW_INSECURE_TOKEN_STORAGE=false

# TTL for mock auth tokens in milliseconds.
# Example: 604800000 (7 days)
EXPO_PUBLIC_MOCK_TOKEN_TTL_MS=604800000

# Require refresh-token rotation (refresh endpoint must return refresh_token).
# Allowed: true | false
EXPO_PUBLIC_REQUIRE_REFRESH_ROTATION=false

# Auth data source.
# Allowed: api | mock
EXPO_PUBLIC_AUTH_SOURCE=api

# Catalog data source.
# Allowed: api | mock
# Demo before /cars API is live: mock
EXPO_PUBLIC_CATALOG_SOURCE=mock

# Reports data source.
# Allowed: api | mock
EXPO_PUBLIC_REPORTS_SOURCE=mock

# Public Sentry DSN for client-side error reporting.
# Example: https://<key>@o0.ingest.sentry.io/<project-id>
EXPO_PUBLIC_SENTRY_DSN=

# Sentry environment tag.
# Example: development | staging | production
EXPO_PUBLIC_SENTRY_ENVIRONMENT=production

# AI picker BFF (ai-api). Local dev: http://localhost:8787 (or LAN IP on device).
# Staging/preview: https://ai-api.n-avtosalon.ru (see ai-api/README.md).
EXPO_PUBLIC_AI_API_URL=

# When true, chat uses local rules if ai-api is unreachable (dev only).
# EXPO_PUBLIC_AI_API_FALLBACK_LOCAL=true

# Staging contract test (opt-in): npm run test:contract:auth
# CONTRACT_TEST=1
# CONTRACT_API_URL=https://indep.su/api/v1.0
# CONTRACT_AUTH_EMAIL=
# CONTRACT_AUTH_OTP=
# CONTRACT_AUTH_OTP_PROVIDER=env
# CONTRACT_AUTH_NAME=
# CONTRACT_AUTH_ROLE=client

# Figma sync (local only — npm run figma:pull). See docs/FIGMA.md
# FIGMA_ACCESS_TOKEN=figd_...
# FIGMA_FILE_KEY=
