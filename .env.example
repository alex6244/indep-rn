# Base API URL.
# Example: https://api.example.com/api
EXPO_PUBLIC_API_URL=https://api.example.com/api

# Allow local HTTP fallback URL in development only.
# Allowed: true | false
EXPO_PUBLIC_ALLOW_HTTP_DEV=false

# Request timeout for API calls in milliseconds.
# Example: 10000
EXPO_PUBLIC_API_TIMEOUT_MS=10000

# Allow token fallback to AsyncStorage when SecureStore is unavailable.
# Allowed: true | false
EXPO_PUBLIC_ALLOW_INSECURE_TOKEN_STORAGE=false

# TTL for mock auth tokens in milliseconds.
# Example: 604800000 (7 days)
EXPO_PUBLIC_MOCK_TOKEN_TTL_MS=604800000

# Require refresh-token rotation (refresh endpoint must return refresh_token).
# Allowed: true | false
EXPO_PUBLIC_REQUIRE_REFRESH_ROTATION=false

# Auth data source.
# Allowed: api | mock
EXPO_PUBLIC_AUTH_SOURCE=api

# Catalog data source.
# Allowed: api | mock
EXPO_PUBLIC_CATALOG_SOURCE=api

# Reports data source.
# Allowed: api | mock
EXPO_PUBLIC_REPORTS_SOURCE=api

# Public Sentry DSN for client-side error reporting.
# Example: https://<key>@o0.ingest.sentry.io/<project-id>
EXPO_PUBLIC_SENTRY_DSN=

# Sentry environment tag.
# Example: development | staging | production
EXPO_PUBLIC_SENTRY_ENVIRONMENT=production
