PORT=8787
# Позже: DEEPSEEK_API_KEY=sk-...

# CORS (через запятую). Пусто в dev = localhost Expo. В production задайте явно.
# AI_API_CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://indep.su

# Rate limit (запросов в минуту на IP)
# AI_API_RATE_LIMIT_ENABLED=true
# AI_API_RATE_CHAT_PER_MIN=30
# AI_API_RATE_LEADS_PER_MIN=10
# AI_API_RATE_META_PER_MIN=60

# Опционально: для виджетов на сайтах с Origin (не для RN — там Origin нет)
# AI_API_CLIENT_KEY=your-partner-secret

# Dev-only: GET /v1/leads (нужны оба)
# AI_API_DEV_LEADS=true
# AI_API_DEV_KEY=your-dev-secret
